          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["projets"]
        }
      }
    },
    {
  "name": "GET ONE - Projet spécifique",
  "event": [
    {
      "listen": "test",
      "script": {
        "exec": [
          "pm.test(\"Status code is 200\", function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "pm.test(\"Projet trouvé\", function () {",
          "    const jsonData = pm.response.json();",
          "    pm.expect(jsonData.id).to.exist;",
          "    pm.expect(jsonData.titre).to.exist;",
          "    pm.collectionVariables.set(\"projetId\", jsonData.id);",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "request": {
