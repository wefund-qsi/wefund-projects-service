{
  "info": {
    "_postman_id": "campagne-test",
    "name": "WeFund-Campagnes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API Campagnes WeFund - CREATE + GET ALL + GET ONE (PUBLIC)"
  },
  "item": [
    {
      "name": "CREATE - Nouvelle campagne (AUTH)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer dummy-token",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titre\": \"Équiper 50 enfants en laptops coding\",\n  \"description\": \"50 laptops + logiciels pour nos ateliers code. Objectif : former 100% des inscrits dès septembre 2026 ! Chaque don = 1h de code pour un enfant.\",\n  \"objectif\": 7500,\n  \"dateFin\": \"2026-09-30T23:59:59.999Z\",\n  \"projetId\": \"{{projetId}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3000/campagnes",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["campagnes"]
        }
      }
    },
    {
      "name": "GET ALL - Toutes les campagnes (PUBLIC)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Au moins 1 campagne\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "    pm.expect(jsonData.length).to.be.above(0);",
              "});",
              "",
              "// Sauvegarde le 1er ID pour test suivant",
              "if (pm.response.json().length > 0) {",
              "    pm.collectionVariables.set(\"campagneId\", pm.response.json()[0].id);",
              "    console.log(\"campagneId sauvée: \" + pm.response.json()[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/campagnes",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["campagnes"]
        }
      }
    },
    {
      "name": "GET ONE - Campagne spécifique (PUBLIC)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/campagnes/{{campagneId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["campagnes", "{{campagneId}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "projetId",
      "value": "f831d590-5ce3-4d77-976d-6c8bc62712ec",
      "description": "ID projet Cours d'informatique"
    },
    {
      "key": "campagneId",
      "value": "",
      "description": "AUTO-rempli par GET ALL (test script)"
    }
  ]
}
